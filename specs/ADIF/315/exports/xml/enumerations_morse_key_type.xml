<?xml version="1.0" encoding="utf-8"?>
<adif version="3.1.5" status="Released" date="2024-11-28T00:00:00Z" created="2024-11-28T09:19:09Z">
  <enumerations>
    <enumeration name="Morse_Key_Type">
      <header>
        <value>Enumeration Name</value>
        <value>Abbreviation</value>
        <value>Meaning</value>
        <value>Characteristics</value>
        <value>Morse Composition</value>
        <value>Examples</value>
        <value>Import-only</value>
        <value>Comments</value>
      </header>
      <record>
        <value name="Enumeration Name">Morse_Key_Type</value>
        <value name="Abbreviation">SK</value>
        <value name="Meaning">Straight Key</value>
        <value name="Characteristics">a single control which actuates a single switch.</value>
        <value name="Morse Composition">a human makes the dits and dahs and builds characters</value>
        <value name="Examples">Lionel J-38</value>
      </record>
      <record>
        <value name="Enumeration Name">Morse_Key_Type</value>
        <value name="Abbreviation">SS</value>
        <value name="Meaning">Sideswiper</value>
        <value name="Characteristics">a single control which actuates a SPDT (single poll, double throw) switch.</value>
        <value name="Morse Composition">a human makes the dits and dahs and builds characters</value>
        <value name="Examples">W1SFR Green Machine Torsion Bar Cootie</value>
      </record>
      <record>
        <value name="Enumeration Name">Morse_Key_Type</value>
        <value name="Abbreviation">BUG</value>
        <value name="Meaning">Mechanical semi-automatic keyer or Bug</value>
        <value name="Characteristics">a control which actuates a switch as well as a control which actuates a spring and pendulum mechanism which actuates a switch. Both switches are wired in parallel.</value>
        <value name="Morse Composition">a machine makes the dits and a human makes the dahs and builds characters.</value>
        <value name="Examples">Vibroplex Blue Racer Deluxe</value>
      </record>
      <record>
        <value name="Enumeration Name">Morse_Key_Type</value>
        <value name="Abbreviation">FAB</value>
        <value name="Meaning">Mechanical fully-automatic keyer or Bug</value>
        <value name="Characteristics">a control which actuates one of two separate spring and pendulum mechanisms at a time, each of which actuates a switch. Both switches are wired in parallel.</value>
        <value name="Morse Composition">a machine makes the dits and the dahs and a human builds characters.</value>
        <value name="Examples">GHD GN209FA fully-automatic bug</value>
      </record>
      <record>
        <value name="Enumeration Name">Morse_Key_Type</value>
        <value name="Abbreviation">SP</value>
        <value name="Meaning">Single Paddle</value>
        <value name="Characteristics">a single control which actuates two independent switches.</value>
        <value name="Morse Composition">a machine makes the dits and the dahs and a human builds the characters.</value>
        <value name="Examples">American Morse Mini-B</value>
      </record>
      <record>
        <value name="Enumeration Name">Morse_Key_Type</value>
        <value name="Abbreviation">DP</value>
        <value name="Meaning">Dual Paddle</value>
        <value name="Characteristics">two controls which actuate independent switches.</value>
        <value name="Morse Composition">a machine makes the dits and the dahs and a human builds the characters.</value>
        <value name="Examples">Begali Sculpture, VK3IL pressure paddles, M0UKD capacitive touch paddles</value>
      </record>
      <record>
        <value name="Enumeration Name">Morse_Key_Type</value>
        <value name="Abbreviation">CPU</value>
        <value name="Meaning">Computer Driven</value>
        <value name="Characteristics">an electronic device performs the actuation of the switch.</value>
        <value name="Morse Composition">a machine makes the dits and dahs to build the characters.</value>
        <value name="Examples">N1MM+ Logging Software</value>
      </record>
    </enumeration>
  </enumerations>
</adif>